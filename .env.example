# MemMark environment template. Copy to .env and fill in private values.
# Never commit .env.

# ---------------------------------------------------------------------------
# Data and local paths
# ---------------------------------------------------------------------------
export MEMMARK_LOCOMO_PATH="/path/to/locomo/data/locomo10.json"

# A-MEM embedding model. Can be a Hugging Face model id or a local directory.
export AMEM_MODEL_NAME="sentence-transformers/all-MiniLM-L6-v2"

# Set to 1 if the embedding model is already available locally.
export TRANSFORMERS_OFFLINE=0
export HF_HUB_OFFLINE=0
export PYTHONUNBUFFERED=1

# ---------------------------------------------------------------------------
# Target/QA LLM
# Used by LoCoMo QA answering/fact extraction and as the default MemMark client.
# Any OpenAI-compatible chat endpoint can be used.
# ---------------------------------------------------------------------------
export TARGET_LLM_BASE="https://api.openai.com/v1"
export TARGET_LLM_MODEL="deepseek-v4-pro"
export TARGET_LLM_API_KEY="replace-me"
# Optional provider-specific JSON, for example: '{"enable_thinking": false}'
# export TARGET_LLM_EXTRA_BODY='{}'

export MEMMARK_BASE_URL="$TARGET_LLM_BASE"
export MEMMARK_MODEL="$TARGET_LLM_MODEL"
export MEMMARK_API_KEY="$TARGET_LLM_API_KEY"
# export MEMMARK_EXTRA_BODY="$TARGET_LLM_EXTRA_BODY"
export MEMMARK_OPENAI_TIMEOUT=60

# Watermark configuration. Change the key for real deployments.
export MEMMARK_KEY="memmark-dev-key-change-me"
export MEMMARK_TARGET_K=4

# ---------------------------------------------------------------------------
# A-MEM native LLM config
# scripts/run_locomo_amem.sh maps these variables to OPENAI_* for A-MEM.
# If unset, the script falls back to TARGET_LLM_*.
# ---------------------------------------------------------------------------
export AMEM_OPENAI_BASE_URL="$TARGET_LLM_BASE"
export AMEM_OPENAI_MODEL="$TARGET_LLM_MODEL"
export AMEM_OPENAI_API_KEY="$TARGET_LLM_API_KEY"
# export AMEM_OPENAI_EXTRA_BODY="$TARGET_LLM_EXTRA_BODY"

# ---------------------------------------------------------------------------
# Graphiti internal extraction/reranking LLM config
# scripts/run_locomo_graphiti.sh maps these variables to OPENAI_* for Graphiti.
# You may use the same model as TARGET_LLM_* or a separate cheaper extraction model.
# ---------------------------------------------------------------------------
export GRAPHITI_OPENAI_BASE_URL="$TARGET_LLM_BASE"
export GRAPHITI_OPENAI_API_KEY="$TARGET_LLM_API_KEY"
export GRAPHITI_OPENAI_MODEL="$TARGET_LLM_MODEL"

export GRAPHITI_RERANKER_BASE_URL="$GRAPHITI_OPENAI_BASE_URL"
export GRAPHITI_RERANKER_API_KEY="$GRAPHITI_OPENAI_API_KEY"
export GRAPHITI_RERANKER_MODEL="$GRAPHITI_OPENAI_MODEL"

# Graphiti embedding endpoint.
export GRAPHITI_EMBEDDING_BASE_URL="$TARGET_LLM_BASE"
export GRAPHITI_EMBEDDING_API_KEY="$TARGET_LLM_API_KEY"
export GRAPHITI_EMBEDDING_MODEL="text-embedding-3-small"
export GRAPHITI_EMBEDDING_DIM=1536
export EMBEDDING_DIM="$GRAPHITI_EMBEDDING_DIM"

# Neo4j for Graphiti.
export NEO4J_URI="bolt://localhost:7687"
export NEO4J_USER="neo4j"
export NEO4J_PASSWORD="memmark-neo4j-pass"

# KGMark-on-Graphiti baseline defaults.
export KGMARK_GRAPHITI_STRENGTH=0.08
export KGMARK_GRAPHITI_MASK_RATIO=0.08

# Optional run-size overrides for quick tests.
# export MAX_SESSIONS=1
# export MAX_QA=2
# export ASYNC_MAX_CONCURRENCY=1
